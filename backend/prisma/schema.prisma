generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PromoType {
  PERCENTAGE
  FIXED
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  password     String
  firstName    String?
  lastName     String?
  role         Role      @default(USER)
  refreshToken String?   // hashed refresh token stocké en DB

  addresses    Address[]
  orders       Order[]

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("users")
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  firstName String
  lastName  String
  street    String
  city      String
  zip       String
  country   String   @default("FR")
  phone     String?
  isDefault Boolean  @default(false)

  createdAt DateTime @default(now())

  @@map("addresses")
}

// ─────────────────────────────────────────────
// CATALOGUE
// ─────────────────────────────────────────────

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  imageUrl    String?
  imagePublicId String? // Cloudinary public_id

  products    Product[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("categories")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  price       Int      // Prix en centimes (ex: 4500 = 45,00€)
  comparePrice Int?    // Prix barré (promotionnel)
  stock       Int      @default(0)
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)

  categoryId  String?
  category    Category?        @relation(fields: [categoryId], references: [id])

  images      ProductImage[]
  variants    ProductVariant[]
  orderItems  OrderItem[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("products")
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  url       String
  publicId  String  // Cloudinary public_id pour suppression
  alt       String?
  order     Int     @default(0)

  @@map("product_images")
}

model ProductVariant {
  id              String  @id @default(cuid())
  productId       String
  product         Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  name            String  // ex: "Couleur", "Taille", "Contenance"
  value           String  // ex: "Rouge", "L", "500ml"
  stock           Int     @default(0)
  priceAdjustment Int     @default(0) // en centimes, peut être négatif
  sku             String? @unique

  orderItems      OrderItem[]

  createdAt       DateTime @default(now())

  @@map("product_variants")
}

// ─────────────────────────────────────────────
// COMMANDES
// ─────────────────────────────────────────────

model Order {
  id              String      @id @default(cuid())
  userId          String?
  user            User?       @relation(fields: [userId], references: [id])

  status          OrderStatus @default(PENDING)

  subtotal        Int         // avant remise, en centimes
  discountAmount  Int         @default(0) // montant de la remise en centimes
  shippingCost    Int         @default(0) // en centimes
  total           Int         // total final en centimes

  promoCode       String?
  promoId         String?

  stripeSessionId  String?    @unique
  stripePaymentId  String?

  // Snapshot de l'adresse au moment de la commande (JSON)
  shippingAddress Json?
  billingAddress  Json?

  // Email pour commandes invité
  guestEmail      String?

  items           OrderItem[]

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@map("orders")
}

model OrderItem {
  id        String          @id @default(cuid())
  orderId   String
  order     Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product         @relation(fields: [productId], references: [id])

  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  quantity  Int
  unitPrice Int             // snapshot du prix au moment de la commande

  // Snapshot du nom produit (au cas où le produit est supprimé)
  productName   String
  variantLabel  String?

  @@map("order_items")
}

// ─────────────────────────────────────────────
// PROMOTIONS
// ─────────────────────────────────────────────

model Promo {
  id             String    @id @default(cuid())
  code           String    @unique
  type           PromoType @default(PERCENTAGE)

  // PERCENTAGE: valeur en % (ex: 10 = 10%)
  // FIXED: valeur en centimes (ex: 500 = 5,00€ de remise)
  value          Int

  minOrderAmount Int?      // montant minimum de commande en centimes
  maxUses        Int?      // null = illimité
  usedCount      Int       @default(0)
  isActive       Boolean   @default(true)
  expiresAt      DateTime?

  createdAt      DateTime  @default(now())

  @@map("promos")
}
